{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Bookings Schema",
  "type": "array",

  "items": {
    "type": "object",
    "required": ["id", "player", "team", "facility"],

    "properties": {
      "id": {
        "type": "string"
      },
      "player": {
        "type": "string"
      },
      "team": {
        "type": "string"
      },
      "facility": {
        "type": "string"
      }
    }
  }
}